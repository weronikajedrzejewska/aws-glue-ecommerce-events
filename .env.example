# General
ENV=dev
LOG_LEVEL=INFO

# AWS
AWS_REGION=eu-central-1
AWS_PROFILE=
S3_RAW_BUCKET=
S3_CURATED_BUCKET=
ATHENA_OUTPUT_S3=
